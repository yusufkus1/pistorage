PORT=3001
HTTPS_PORT=3443
JWT_SECRET=your-very-long-random-secret-key-here

# Şifre hash'i oluşturmak için:
#   docker compose run --rm setup-password
PASSWORD_HASH=

# Raspberry Pi'nin yerel IP adresi (HTTPS sertifikası için)
# Öğrenmek için Pi'de çalıştır: hostname -I | awk '{print $1}'
PI_IP=192.168.1.x
